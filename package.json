{
  "name": "fila-virtual",
  "version": "1.0.0",
  "description": "Sistema de gestión de turnos - Venta de Repuestos",
  "main": "src/handlers/admin.js",
  "scripts": {
    "start": "sam local start-api --env-vars env.json --docker-network fila-virtual_default",
    "start:detached": "sam local start-api --env-vars env.json --docker-network fila-virtual_default &",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "seed": "bash scripts/seed-local.sh",
    "setup": "npm run docker:up && sleep 5 && npm run seed",
    "build": "sam build",
    "validate": "sam validate",
    "logs": "sam logs --tail",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.540.0",
    "@aws-sdk/client-dynamodb": "^3.540.0",
    "@aws-sdk/client-polly": "^3.1001.0",
    "@aws-sdk/lib-dynamodb": "^3.540.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
